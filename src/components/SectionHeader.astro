---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-8 space-y-3">
  {eyebrow && <p class="section-kicker">{eyebrow}</p>}
  <h2 class="section-title">{title}</h2>
  {description && <p class="max-w-3xl text-sm leading-7 text-slate-300 md:text-base">{description}</p>}
</header>
