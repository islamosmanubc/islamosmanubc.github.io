---
import TagPill from "./TagPill.astro";

interface SchoolProject {
  slug: string;
  display_name: string;
  project_type: string;
  summary: string;
  blog_paragraphs: string[];
  thumbnail?: string;
  stack: {
    languages: string[];
    tools: string[];
    concepts: string[];
  };
}

interface Props {
  project: SchoolProject;
}

const { project } = Astro.props;

const archiveLeadIns = [
  "This folder preserves ",
  "This folder contains a packaged ",
  "This folder packages the deployable version of ",
  "This folder captures ",
  "This folder holds the distributable version of ",
  "This folder looks like a packaged ",
  "This folder packages the finished "
];

const normalizeParagraph = (paragraph: string) => {
  const matchedPrefix = archiveLeadIns.find((prefix) => paragraph.startsWith(prefix));

  if (!matchedPrefix) {
    return paragraph;
  }

  const trimmed = paragraph.slice(matchedPrefix.length);
  return trimmed ? `${trimmed.charAt(0).toUpperCase()}${trimmed.slice(1)}` : paragraph;
};

const stackItems = [
  ...project.stack.languages,
  ...project.stack.tools.slice(0, 3),
  ...project.stack.concepts.slice(0, 3)
];

const base = import.meta.env.BASE_URL;
const thumbnail = project.thumbnail ? `${base}${project.thumbnail.replace(/^\//, "")}` : undefined;
---

<article class="card-shell flex h-full flex-col p-6 md:p-7">
  {thumbnail && (
    <img
      src={thumbnail}
      alt={`${project.display_name} project screenshot`}
      class="mb-6 block h-56 w-full rounded-2xl border border-white/8 object-cover object-top shadow-[0_20px_50px_rgba(2,6,23,0.35)]"
      loading="lazy"
      decoding="async"
    />
  )}

  <div class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200/80">
      {project.project_type}
    </p>
    <h3 class="mt-3 text-2xl font-semibold tracking-tight text-white">{project.display_name}</h3>
  </div>

  <p class="mt-4 text-sm leading-7 text-slate-300">{project.summary}</p>

  <div class="mt-5 flex flex-wrap gap-2">
    {stackItems.map((item) => <TagPill label={item} />)}
  </div>

  <div class="soft-divider my-5"></div>

  <div class="space-y-4 text-sm leading-7 text-slate-300">
    {project.blog_paragraphs.map((paragraph) => <p>{normalizeParagraph(paragraph)}</p>)}
  </div>
</article>
