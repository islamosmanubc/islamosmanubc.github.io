---
import TagPill from "./TagPill.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  publication: CollectionEntry<"publications">;
  compact?: boolean;
}

const { publication, compact = false } = Astro.props;
const { title, venue, authors, year, category, tags, links } = publication.data;
---

<article class={`panel-muted ${compact ? "p-5" : "p-6"} h-full`}>
  <div class="flex flex-wrap items-center gap-3 text-xs text-slate-400">
    <span class="rounded-full border border-white/10 px-3 py-1">{category}</span>
    <span>{venue}</span>
    <span>|</span>
    <span>{year}</span>
  </div>

  <h3 class={`mt-4 font-semibold tracking-tight text-white ${compact ? "text-lg" : "text-xl"}`}>
    {title}
  </h3>

  <p class="mt-3 text-sm leading-7 text-slate-300">{authors}</p>

  {tags.length > 0 && (
    <div class="mt-4 flex flex-wrap gap-2">
      {tags.map((tag) => <TagPill label={tag} />)}
    </div>
  )}

  {links && (
    <div class="mt-5 flex flex-wrap gap-4 text-sm">
      {links.paper && (
        <a href={links.paper} class="text-cyan-200 hover:text-white" target="_blank" rel="noreferrer">
          Paper
        </a>
      )}
      {links.scholar && (
        <a href={links.scholar} class="text-cyan-200 hover:text-white" target="_blank" rel="noreferrer">
          Scholar
        </a>
      )}
    </div>
  )}
</article>
