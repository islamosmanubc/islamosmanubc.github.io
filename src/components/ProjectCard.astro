---
import TagPill from "./TagPill.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const base = import.meta.env.BASE_URL;
const cover = `${base}${project.data.cover.replace(/^\//, "")}`;
---

<article class="card-shell hover-lift flex h-full flex-col overflow-hidden">
  <a href={`${base}projects/${project.data.slug}/`} class="block">
    <img
      src={cover}
      alt={`${project.data.title} cover image`}
      class="block h-48 w-full object-cover object-center"
      loading="eager"
      decoding="async"
    />
  </a>

  <div class="flex flex-1 flex-col gap-4 p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-sm text-cyan-200/80">{project.data.period}</p>
        <h3 class="mt-1 text-xl font-semibold tracking-tight text-white">
          <a href={`${base}projects/${project.data.slug}/`} class="hover:text-cyan-200">
            {project.data.title}
          </a>
        </h3>
      </div>
      <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">
        {project.data.year}
      </span>
    </div>

    <p class="text-sm font-medium text-slate-200">{project.data.subtitle}</p>
    <p class="text-sm leading-7 text-slate-400">{project.data.summary}</p>

    <div class="flex flex-wrap gap-2">
      {project.data.tags.slice(0, 4).map((tag) => <TagPill label={tag} />)}
    </div>

    <div class="soft-divider my-2"></div>

    <p class="text-sm leading-7 text-slate-300">{project.data.impact}</p>

    <div class="mt-auto flex items-center justify-between gap-4 pt-2">
      <div class="flex flex-wrap gap-2 text-xs text-slate-400">
        {project.data.stack.slice(0, 3).map((item) => (
          <span class="rounded-full border border-white/8 px-3 py-1">{item}</span>
        ))}
      </div>
      <a
        href={`${base}projects/${project.data.slug}/`}
        class="text-sm font-medium text-cyan-200 hover:text-white"
      >
        View project -&gt;
      </a>
    </div>
  </div>
</article>
