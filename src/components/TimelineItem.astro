---
interface Props {
  title: string;
  subtitle: string;
  period: string;
  location?: string;
  bullets?: string[];
}

const { title, subtitle, period, location, bullets = [] } = Astro.props;
---

<div class="relative pl-8">
  <div class="absolute left-0 top-2 h-3 w-3 rounded-full bg-cyan-300 shadow-[0_0_0_6px_rgba(34,211,238,0.08)]"></div>
  <div class="absolute left-[5px] top-5 h-[calc(100%-0.5rem)] w-px bg-white/10"></div>

  <div class="panel-muted p-6">
    <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
      <div>
        <h3 class="text-lg font-semibold text-white">{title}</h3>
        <p class="text-sm text-cyan-200">{subtitle}</p>
        {location && <p class="mt-1 text-sm text-slate-400">{location}</p>}
      </div>
      <div class="rounded-full border border-white/10 px-3 py-1 text-xs text-slate-300">{period}</div>
    </div>

    {bullets.length > 0 && (
      <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-300">
        {bullets.map((bullet) => <li>{bullet}</li>)}
      </ul>
    )}
  </div>
</div>
