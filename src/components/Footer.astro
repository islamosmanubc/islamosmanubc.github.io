---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="mt-8 card-shell p-6 text-sm text-slate-400">
  <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
    <p>Copyright {year} Islam Osman.</p>
    <div class="flex flex-wrap gap-4">
      <a href={`${base}projects/`} class="hover:text-white">Projects</a>
      <a href={`${base}publications/`} class="hover:text-white">Publications</a>
      <a href={`${base}education/`} class="hover:text-white">Education</a>
      <a href={`${base}cv/`} class="hover:text-white">CV</a>
      <a href={`${base}contact/`} class="hover:text-white">Contact</a>
    </div>
  </div>
</footer>
