---
import SectionHeader from "../components/SectionHeader.astro";
import SkillGroup from "../components/SkillGroup.astro";
import Layout from "../layouts/Layout.astro";
import {
  aboutParagraphs,
  awards,
  currentThemes,
  service,
  skillGroups,
  teaching,
  whatIBring
} from "../data/site";
---

<Layout
  title="About - Islam Osman"
  description="Background, technical focus, mentoring, and research themes for Islam Osman."
>
  <div class="space-y-6">
    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="About"
        title="A researcher-engineer profile built around vision, multimodality, and deployable ML."
      />
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-5 text-base leading-8 text-slate-300">
          {aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
        <div class="space-y-4">
          <div class="panel-muted p-6">
            <h3 class="text-lg font-semibold text-white">What I bring</h3>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-300">
              {whatIBring.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="panel-muted p-6">
            <h3 class="text-lg font-semibold text-white">Current themes</h3>
            <ul class="mt-4 space-y-3 text-sm leading-7 text-slate-300">
              {currentThemes.map((item) => <li>{item}</li>)}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Skills"
        title="Technical capabilities"
        description="A portfolio-friendly view of the tools and domains that show up repeatedly across the work."
      />
      <div class="grid gap-4 lg:grid-cols-2">
        {skillGroups.map((group) => <SkillGroup title={group.title} items={group.items} />)}
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Teaching and mentoring"
        title="Academic leadership beyond publication output"
        description="Teaching, lab support, and graduate mentorship have been a consistent part of the work."
      />
      <div class="grid gap-4 lg:grid-cols-2">
        {teaching.slice(0, 4).map((item) => (
          <div class="panel-muted p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-400">{item.period}</p>
            <h3 class="mt-2 text-lg font-semibold text-white">{item.role}</h3>
            <p class="mt-1 text-sm text-cyan-200">{item.organization}</p>
            <ul class="mt-4 space-y-2 text-sm leading-7 text-slate-300">
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <section class="grid gap-6 lg:grid-cols-2">
      <div class="card-shell p-8">
        <SectionHeader eyebrow="Awards" title="Recognition" />
        <ul class="space-y-3 text-sm leading-7 text-slate-300">
          {awards.map((item) => <li>{item}</li>)}
        </ul>
      </div>

      <div class="card-shell p-8">
        <SectionHeader eyebrow="Service" title="Editorial and community roles" />
        <ul class="space-y-3 text-sm leading-7 text-slate-300">
          {service.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
  </div>
</Layout>
