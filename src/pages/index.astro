---
import { getCollection } from "astro:content";
import ContactCard from "../components/ContactCard.astro";
import Hero from "../components/Hero.astro";
import ProjectGrid from "../components/ProjectGrid.astro";
import PublicationCard from "../components/PublicationCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TagPill from "../components/TagPill.astro";
import Layout from "../layouts/Layout.astro";
import {
  aboutParagraphs,
  contacts,
  education,
  experience,
  focusAreas,
  homeHighlights,
  profile
} from "../data/site";

const projects = (await getCollection("projects"))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((project) => project.data.featured)
  .slice(0, 6);

const publications = (await getCollection("publications"))
  .sort((a, b) => a.data.order - b.data.order)
  .filter((publication) => publication.data.featured)
  .slice(0, 4);

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Islam Osman, PhD - AI Researcher and Machine Learning Engineer"
  description="Project-first portfolio for Islam Osman featuring autonomous driving, medical imaging, continual learning, and multimodal AI work."
>
  <div class="space-y-6">
    <Hero />

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="About"
        title="Research depth with product-minded execution."
        description="Built for recruiters, collaborators, and labs that want the project story first and the CV context second."
      />
      <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
        <div class="space-y-4 text-base leading-8 text-slate-300">
          {aboutParagraphs.slice(0, 2).map((paragraph) => <p>{paragraph}</p>)}
          <a href={`${base}about/`} class="text-sm font-medium text-cyan-200 hover:text-white">
            Read the full background -&gt;
          </a>
        </div>
        <div class="grid gap-4">
          {homeHighlights.map((item) => (
            <div class="panel-muted p-6">
              <h3 class="text-lg font-semibold text-white">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.text}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-2">
        {focusAreas.map((item) => <TagPill label={item} />)}
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Featured projects"
        title="Selected systems, research tools, and applied AI builds."
        description="The strongest work here combines modeling, tooling, and workflow design rather than isolated experiments."
      />
      <ProjectGrid projects={projects} />
      <div class="mt-8">
        <a href={`${base}projects/`} class="text-sm font-medium text-cyan-200 hover:text-white">
          Browse all projects -&gt;
        </a>
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Selected publications"
        title="Research contributions across continual learning, medical imaging, and video understanding."
        description="A curated selection from 25 papers and 2 refereed abstracts."
      />
      <div class="grid gap-6 lg:grid-cols-2">
        {publications.map((publication) => <PublicationCard publication={publication} compact />)}
      </div>
      <div class="mt-8">
        <a href={`${base}publications/`} class="text-sm font-medium text-cyan-200 hover:text-white">
          View the publication list -&gt;
        </a>
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Experience"
        title="Industry collaboration, research leadership, and teaching."
        description="A concise snapshot of the roles behind the project and publication work."
      />
      <div class="grid gap-4 md:grid-cols-2">
        {experience.slice(0, 4).map((item) => (
          <div class="panel-muted p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-400">{item.period}</p>
            <h3 class="mt-2 text-lg font-semibold text-white">{item.role}</h3>
            <p class="mt-1 text-sm text-cyan-200">{item.organization}</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.bullets[0]}</p>
          </div>
        ))}
      </div>
      <div class="mt-8">
        <a href={`${base}experience/`} class="text-sm font-medium text-cyan-200 hover:text-white">
          View the full timeline -&gt;
        </a>
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Education"
        title="Academic foundations"
        description="A focused academic record that supports the portfolio instead of overwhelming it."
      />
      <div class="grid gap-4 lg:grid-cols-3">
        {education.map((item) => (
          <div class="panel-muted p-6">
            <p class="text-xs uppercase tracking-[0.18em] text-slate-400">{item.period}</p>
            <h3 class="mt-2 text-lg font-semibold text-white">{item.degree}</h3>
            <p class="mt-1 text-sm text-cyan-200">{item.school}</p>
            <p class="mt-3 text-sm leading-7 text-slate-300">{item.detail}</p>
          </div>
        ))}
      </div>
      <div class="mt-8">
        <a href={`${base}education/`} class="text-sm font-medium text-cyan-200 hover:text-white">
          View education and honors -&gt;
        </a>
      </div>
    </section>

    <section class="card-shell p-8 md:p-10">
      <SectionHeader
        eyebrow="Contact"
        title="Open to research, engineering, and collaboration conversations."
        description={profile.summary}
      />
      <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="panel-muted p-6">
          <p class="text-sm leading-7 text-slate-300">
            Email is the fastest way to reach me. You can also use GitHub to review public code and Google Scholar to browse publications and citations.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href={`mailto:${profile.email}`}
              class="rounded-full bg-cyan-300 px-5 py-3 text-sm font-semibold text-slate-950 hover:bg-white"
            >
              Email Islam
            </a>
            <a
              href={`${base}cv/`}
              class="rounded-full border border-white/10 px-5 py-3 text-sm font-semibold text-white hover:border-cyan-300/40 hover:text-cyan-100"
            >
              View CV page
            </a>
          </div>
        </div>

        <div class="grid gap-4">
          {contacts.map((item) => (
            <ContactCard
              label={item.label}
              value={item.value}
              href={item.href}
              description={item.description}
            />
          ))}
        </div>
      </div>
    </section>
  </div>
</Layout>
